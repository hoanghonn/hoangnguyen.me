<section class="contact-strip reveal" id="contact">
  <div class="contact-info">
    <div class="em">hoangnguyen.me</div>
    <div>(+84) 93-858-0110</div>
    <div>Le Thanh Street, Ba Dinh District</div>
    <div>Hanoi, Vietnam 100000</div>
  </div>
  <div class="contact-actions">
    <a class="btn btn-ghost" href="https://www.linkedin.com/in/hoanghonn/" target="_blank" rel="noopener">LINKEDIN <span class="arr">↗</span></a>
    <a class="btn btn-ghost" href="https://github.com/hoanghonn" target="_blank" rel="noopener">GITHUB <span class="arr">↗</span></a>
  </div>
</section>

<style>
  .contact-strip {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 64px;
    padding: 36px 0 80px;
    border-top: 1px solid var(--rule);
  }
  .contact-info { color: var(--fg-dim); font-size: 12px; line-height: 1.85; }
  .contact-info .em { color: var(--fg); }
  .contact-actions { display: flex; gap: 12px; flex-shrink: 0; }
  @media (max-width: 640px) {
    .contact-strip { flex-direction: column; gap: 28px; padding: 32px 0 60px; }
    .contact-actions { flex-wrap: wrap; }
  }
</style>
