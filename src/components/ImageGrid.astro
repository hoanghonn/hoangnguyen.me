---
interface Props {
  images: { src: string; alt?: string }[];
  columns?: number;
}

const { images, columns = 3 } = Astro.props;
---

<div class="image-grid" style={`--cols: ${columns}`}>
  {images.map((img) => (
    <div class="image-grid-cell">
      <img src={img.src} alt={img.alt ?? ''} loading="lazy" />
    </div>
  ))}
</div>

<style>
  .image-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 4px;
    margin: 0 0 28px;
  }

  .image-grid-cell {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .image-grid-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .image-grid-cell img:hover {
    transform: scale(1.04);
  }

  @media (max-width: 640px) {
    .image-grid {
      gap: 2px;
    }
  }
</style>
