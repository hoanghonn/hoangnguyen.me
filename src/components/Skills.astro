<section class="section reveal">
  <div class="section-label">SKILLS</div>
  <div class="section-body">
    <div class="glyph">&lt;&gt;</div>
    <h3 class="skills-h">Areas of Expertise</h3>
    <ul class="skills-list">
      <li>Python and its frameworks (Django, Flask, Faust)</li>
      <li>Databases (SQL, PostgreSQL, Google Datastore)</li>
      <li>Queue-based techs (Kafka, Celery, RabbitMQ, Redis)</li>
      <li>Cloud providers (AWS, GCP)</li>
    </ul>
  </div>
</section>

<style>
  .skills-h { font-size: 13px; font-weight: 700; margin: 0 0 14px; }
  .skills-list { color: var(--fg-dim); }
  .skills-list li { padding-left: 16px; position: relative; }
  .skills-list li::before { content: "•"; position: absolute; left: 0; color: var(--accent); }
</style>
