---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Base title="Blog — Hoang Nguyen">
  <div class="page">
    <Nav activePage="blog" borderBottom />

    <div class="toolbar">
      <div class="filters" role="tablist" id="filters">
        <button class="filter-btn active" data-filter="All Posts" role="tab" aria-selected="true">All Posts</button>
        <button class="filter-btn" data-filter="Trail Running" role="tab" aria-selected="false">Trail Running</button>
        <button class="filter-btn" data-filter="Technology" role="tab" aria-selected="false">Technology</button>
      </div>
      <label class="search" aria-label="Search posts">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input type="text" id="search" placeholder="Search..." />
      </label>
    </div>

    <h1 class="page-title" id="page-title">All Posts</h1>

    <div class="grid" id="grid">
      {posts.map((post, i) => (
        <a
          class="card reveal"
          href={`/blog/${post.id}`}
          data-category={post.data.category}
          data-title={post.data.title.toLowerCase()}
          style={`animation-delay: ${i * 60}ms`}
        >
          <div
            class:list={['card-cover', post.data.cover]}
            style={post.data.coverGradient ? `background: ${post.data.coverGradient}` : undefined}
          ></div>
          <div class="card-meta">
            <div class="card-author">
              <div class="avatar"></div>
              <span>Hoang Nguyen</span>
            </div>
            <span class="dot">·</span>
            <span>{post.data.date}</span>
            <span class="dot">·</span>
            <span class="read">{post.data.readTime}</span>
          </div>
          <div class="card-body">
            <span class="tag">{post.data.category}</span>
            <h3 class="card-title">{post.data.title}</h3>
            <div class="card-divider"></div>
            <div class="card-actions">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-8h2.6l.4-3H13V9c0-.9.3-1.5 1.5-1.5H16V4.8c-.3 0-1.2-.1-2.2-.1-2.2 0-3.8 1.3-3.8 3.8V11H7v3h3v8h3z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 3h3l-6.6 7.5L22 21h-6.1l-4.8-6.3L5.6 21H2.5l7-8L2 3h6.2l4.4 5.8L17.5 3zm-1 16h1.7L7.6 5H5.8l10.7 14z"/></svg>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 14a4 4 0 0 0 5.66 0l3.18-3.18a4 4 0 0 0-5.66-5.66l-1.06 1.06" />
                <path d="M14 10a4 4 0 0 0-5.66 0l-3.18 3.18a4 4 0 0 0 5.66 5.66l1.06-1.06" />
              </svg>
              <div class="spacer"></div>
              <svg class="menu" viewBox="0 0 24 24" fill="currentColor"><circle cx="6" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="18" cy="12" r="1.6"/></svg>
            </div>
          </div>
        </a>
      ))}
      <div class="empty-state" id="empty-state" style="display:none">
        No posts match your search.
      </div>
    </div>

    <Footer />
  </div>
</Base>

<script>
  const filters = document.getElementById('filters');
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const grid = document.getElementById('grid');
  const title = document.getElementById('page-title');
  const emptyState = document.getElementById('empty-state');

  let activeFilter = 'All Posts';
  let query = '';

  function update() {
    const cards = grid?.querySelectorAll<HTMLElement>('.card');
    let visible = 0;
    cards?.forEach(card => {
      const cat = card.dataset.category ?? '';
      const cardTitle = card.dataset.title ?? '';
      const matchFilter = activeFilter === 'All Posts' || cat === activeFilter;
      const matchQuery = !query || cardTitle.includes(query.toLowerCase());
      const show = matchFilter && matchQuery;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyState) emptyState.style.display = visible === 0 ? '' : 'none';
    if (title) title.textContent = activeFilter;
  }

  filters?.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLButtonElement | null;
    if (!btn) return;
    filters.querySelectorAll('.filter-btn').forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-selected', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    activeFilter = btn.dataset.filter ?? 'All Posts';
    update();
  });

  searchInput?.addEventListener('input', () => {
    query = searchInput.value.trim();
    update();
  });
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 64px 0 12px;
  }
  .filters { display: flex; gap: 36px; }
  .filter-btn {
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--fg);
    padding: 6px 0;
    cursor: pointer;
    transition: color .15s ease;
  }
  .filter-btn:hover, .filter-btn.active { color: var(--accent); }
  .search {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 9px 14px;
    width: 280px;
    transition: border-color .15s ease;
  }
  .search:focus-within { border-color: var(--accent); }
  .search svg { width: 14px; height: 14px; color: var(--fg-dim); flex-shrink: 0; }
  .search input { flex: 1; font-size: 13px; }
  .search input::placeholder { color: var(--fg-subtle); }

  .page-title { font-size: 38px; font-weight: 700; letter-spacing: 0.02em; margin: 56px 0 36px; }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-bottom: 80px;
  }
  .card {
    position: relative;
    background: var(--card);
    aspect-ratio: 4 / 3.2;
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: transform .35s cubic-bezier(.2,.7,.2,1), box-shadow .35s ease;
    color: var(--fg);
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 18px 44px rgba(0,0,0,0.45); }

  .card-cover {
    position: absolute;
    inset: 0;
    background: var(--card-img);
    background-size: cover;
    background-position: center;
    transition: transform .6s cubic-bezier(.2,.7,.2,1);
  }
  .card:hover .card-cover { transform: scale(1.04); }
  .card-cover.gradient { background: linear-gradient(135deg, #4a4a4a, #2c2c2c); }
  .card-cover.empty { background: linear-gradient(180deg, #3a3a3a 0%, #2e2e2e 100%); }
  .card-cover.illustration {
    background: radial-gradient(circle at 50% 45%, rgba(255,255,255,0.06) 0, transparent 55%), linear-gradient(180deg, #3a3a3a 0%, #2e2e2e 100%);
  }
  .card-cover.photo { background-size: cover; background-position: center; }
  .card-cover.photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.0) 30%, rgba(0,0,0,0.55) 100%);
  }

  .card-meta {
    position: absolute;
    top: 18px;
    left: 20px;
    right: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    color: var(--fg);
    z-index: 2;
  }
  .card-author { display: flex; align-items: center; gap: 8px; }
  .avatar {
    width: 18px; height: 18px; border-radius: 50%;
    background: radial-gradient(circle at 30% 25%, #b9c8ff 0%, #6f7fc6 35%, #2b3a7a 70%, #0e1428 100%);
    flex-shrink: 0;
  }
  .dot, .read { color: var(--fg-dim); }

  .card-body { position: relative; z-index: 2; padding: 0 22px 18px; }
  .tag {
    display: inline-block;
    background: var(--accent);
    color: #06241a;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 8px;
    margin-bottom: 16px;
    letter-spacing: 0.02em;
  }
  .card-title {
    font-size: 19px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 14px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }
.card-actions { display: flex; align-items: center; gap: 18px; color: var(--fg-dim); }
  .card-actions svg { width: 16px; height: 16px; }
  .card-actions svg:hover { color: var(--fg); }
  .spacer { flex: 1; }

  .empty-state {
    grid-column: 1 / -1;
    padding: 80px 0;
    text-align: center;
    color: var(--fg-dim);
    border: 1px dashed var(--rule);
  }

  @media (max-width: 1024px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .toolbar { flex-direction: column; align-items: stretch; gap: 20px; padding: 40px 0 8px; }
    .filters { gap: 20px; flex-wrap: wrap; }
    .filter-btn { font-size: 13px; }
    .search { width: 100%; }
    .page-title { font-size: 26px; margin: 36px 0 24px; }
    .grid { grid-template-columns: 1fr; gap: 16px; padding-bottom: 56px; }
    .card { aspect-ratio: 4 / 2.8; }
  }
</style>
