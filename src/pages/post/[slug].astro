---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Comments from '../../components/Comments.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const all = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const recent = all.filter(p => p.data.slug !== post.data.slug).slice(0, 3);
---
<Base title={`${post.data.title} — Hoang Nguyen`}>
  <div class="page">
    <Nav activePage="blog" borderBottom />

    <article class="post">
      <header class="post-header">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <div class="avatar"></div>
          <span>Hoang Nguyen</span>
          <span class="dot">·</span>
          <span>{post.data.date}</span>
          <span class="dot">·</span>
          <span>{post.data.readTime}</span>
        </div>
      </header>

      {post.data.coverImage ? (
        <img class="post-cover-img" src={post.data.coverImage} alt={post.data.title} />
      ) : (
        <div
          class:list={['post-cover', post.data.cover]}
          style={post.data.coverGradient ? `background: ${post.data.coverGradient}` : undefined}
        ></div>
      )}

      <div class="post-body">
        <Content />
      </div>

      <div class="post-tags">
        <span class="tag">{post.data.category}</span>
      </div>
    </article>

    <section class="recent">
      <div class="recent-head"><span>Recent Posts</span><a href="/blog">See All</a></div>
      <div class="recent-grid">
        {recent.map(p => (
          <a class="recent-card" href={`/post/${p.data.slug}`}>
            <div class="recent-cover" style={p.data.coverImage ? `background-image:url(${p.data.coverImage})` : undefined}></div>
            <h4>{p.data.title}</h4>
            <div class="recent-meta">{p.data.date} · {p.data.readTime}</div>
          </a>
        ))}
      </div>
    </section>

    <Comments />

    <div class="back-row">
      <a href="/blog" class="btn btn-ghost">← BACK TO BLOG</a>
    </div>

    <Footer />
  </div>
</Base>

<style>
  .post { max-width: 760px; margin: 64px auto 0; }
  .post-header { text-align: center; margin-bottom: 36px; }
  .post-title { font-size: 36px; font-weight: 800; line-height: 1.15; margin: 0 0 20px; letter-spacing: 0.01em; }
  .post-meta { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 10px; font-size: 12px; color: var(--fg-dim); }
  .avatar {
    width: 18px; height: 18px; border-radius: 50%;
    background: radial-gradient(circle at 30% 25%, #b9c8ff 0%, #6f7fc6 35%, #2b3a7a 70%, #0e1428 100%);
    flex-shrink: 0;
  }
  .dot { color: var(--fg-subtle); }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 7;
    background: var(--card-img);
    margin-bottom: 48px;
  }
  .post-cover.empty { background: linear-gradient(180deg, #3a3a3a 0%, #2e2e2e 100%); }
  .post-cover.gradient { background: linear-gradient(135deg, #4a4a4a, #2c2c2c); }
  .post-cover.photo { background-size: cover; background-position: center; }
  .post-cover.illustration {
    background: radial-gradient(circle at 50% 45%, rgba(255,255,255,0.06) 0, transparent 55%), linear-gradient(180deg, #3a3a3a 0%, #2e2e2e 100%);
  }
  .post-cover-img { width: 100%; aspect-ratio: 16 / 7; object-fit: cover; margin-bottom: 48px; display: block; }
  @media (max-width: 640px) { .post-cover-img { aspect-ratio: 16 / 9; margin-bottom: 24px; } }

  .post-body { color: var(--fg-dim); line-height: 1.8; font-size: 14px; }
  .post-body :global(h2) { font-size: 18px; font-weight: 700; color: var(--fg); margin: 40px 0 14px; letter-spacing: 0.02em; }
  .post-body :global(h3) { font-size: 15px; font-weight: 700; color: var(--fg); margin: 28px 0 10px; }
  .post-body :global(p) { margin: 0 0 20px; }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 20px; padding-left: 20px; }
  .post-body :global(li) { margin-bottom: 6px; }
  .post-body :global(li::marker) { color: var(--accent); }
  .post-body :global(pre) {
    background: #111;
    border: 1px solid var(--rule);
    padding: 20px;
    overflow-x: auto;
    margin: 0 0 24px;
    font-size: 12px;
    line-height: 1.6;
  }
  .post-body :global(figure) { margin: 0 0 28px; }
  .post-body :global(figure img) { max-width: 100%; height: auto; display: block; width: 100%; }
  .post-body :global(figcaption) { font-size: 12px; color: var(--fg-subtle); text-align: center; margin-top: 10px; letter-spacing: 0.02em; }
  .post-body :global(img) { max-width: 100%; height: auto; display: block; }
  .post-body :global(code) { font-family: inherit; }
  .post-body :global(p code) {
    background: #1a1a1a;
    padding: 2px 6px;
    color: var(--accent);
    font-size: 12px;
  }

  .post-tags { max-width: 760px; margin: 40px auto 0; }
  .post-tags .tag {
    display: inline-block;
    background: var(--accent);
    color: #06241a;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 8px;
    letter-spacing: 0.02em;
  }

  .recent { max-width: 760px; margin: 64px auto 0; }
  .recent-head { display: flex; justify-content: space-between; font-size: 12px; color: var(--fg-dim); margin-bottom: 20px; }
  .recent-head a:hover { color: var(--accent); }
  .recent-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .recent-card h4 { font-size: 13px; margin: 10px 0 4px; line-height: 1.35; }
  .recent-cover { aspect-ratio: 16 / 9; background: var(--card-img); background-size: cover; background-position: center; }
  .recent-meta { font-size: 11px; color: var(--fg-subtle); }
  @media (max-width: 640px) { .recent-grid { grid-template-columns: 1fr; } }

  .back-row { padding: 48px 0 32px; max-width: 760px; margin: 0 auto; }

  @media (max-width: 1024px) {
    .post { max-width: 100%; }
    .back-row { max-width: 100%; }
  }

  @media (max-width: 640px) {
    .post { margin-top: 36px; }
    .post-title { font-size: 24px; line-height: 1.2; }
    .post-meta { flex-wrap: wrap; gap: 6px; font-size: 11px; }
    .post-cover { margin-bottom: 24px; aspect-ratio: 16 / 9; }
    .post-body :global(h2) { font-size: 16px; margin: 28px 0 10px; }
    .post-body :global(h3) { font-size: 14px; margin: 20px 0 8px; }
    .back-row { padding: 32px 0 24px; }
  }
</style>
